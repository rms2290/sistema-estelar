[run]
# Arquivos e diretórios a incluir na cobertura
source = notas

# Arquivos e diretórios a ignorar
omit =
    */migrations/*
    */tests/*
    */__pycache__/*
    */venv/*
    */env/*
    */settings.py
    */settings_production.py
    */wsgi.py
    */asgi.py
    */manage.py
    */admin.py
    */apps.py
    */urls.py
    */middleware.py
    */decorators.py
    */templatetags/*
    */management/commands/*

# Branch coverage
branch = True

[report]
# Excluir linhas da cobertura
exclude_lines =
    # Não contar linhas de pragma
    pragma: no cover
    def __repr__
    raise AssertionError
    raise NotImplementedError
    if __name__ == .__main__.:
    if TYPE_CHECKING:
    @abstractmethod
    @abc.abstractmethod

# Mostrar linhas faltando
show_missing = True

# Precisão de porcentagem
precision = 2

# Ordenar por cobertura
sort = Cover

# Pular arquivos vazios
skip_empty = True

[html]
# Diretório para relatório HTML
directory = htmlcov


